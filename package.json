  "license": "MIT",
  "author": "Intent Compiler Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Deanbucai/intent-compiler"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
