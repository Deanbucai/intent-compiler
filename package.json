{
  "name": "@deanbucai/intent-compiler",
  "version": "0.0.12",
  "description": "Natural Language → Structured Intent IR → Any Output. The LLVM for vibe coding.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "intentc": "./dist/cli.js",
    "intentc-mcp": "./dist/mcp-server.js"
  },
